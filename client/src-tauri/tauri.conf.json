{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Messenger",
  "version": "0.1.0",
  "identifier": "com.example.messenger",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Messenger",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
